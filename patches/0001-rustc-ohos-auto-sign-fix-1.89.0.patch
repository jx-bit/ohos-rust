+// OHOS PATCH START: Helper function for OpenHarmony auto-signing
+fn ohos_auto_resign(sess: &Session, out_filename: &Path) {
+    let sign_tool = match std::env::var("OHOS_BINARY_SIGN_TOOL") {
+        Ok(path) => path,
+        Err(_) => {
+            sess.dcx().warn(
+                "[OhOS Auto-Sign] OHOS_BINARY_SIGN_TOOL env var not set. Skipping signing."
+            );
+            return;
+        }
+    };
+
+    let tmp_signed = out_filename.with_extension("elf.signed_tmp");
+
+    let status = StdCommand::new(&sign_tool)
+        .arg("sign")
+        .arg("-inFile").arg(out_filename)
+        .arg("-outFile").arg(&tmp_signed)
+        .arg("-selfSign").arg("1")
+        .status();
+
+    match status {
+        Ok(s) if s.success() => {
+            if std::fs::rename(&tmp_signed, out_filename).is_err() {
+                let _ = std::fs::copy(&tmp_signed, out_filename);
+                let _ = std::fs::remove_file(&tmp_signed);
+            }
+
+            #[cfg(unix)]
+            {
+                use std::os::unix::fs::PermissionsExt;
+                if let Ok(meta) = std::fs::metadata(out_filename) {
+                    let mut perms = meta.permissions();
+                    perms.set_mode(perms.mode() | 0o755);
+                    let _ = std::fs::set_permissions(out_filename, perms);
+                }
+            }
+
+            sess.dcx().note(format!("[OhOS Auto-Sign] Signed: {}", out_filename.display()));
+        }
+        _ => {
+            sess.dcx().warn(format!("[OhOS Auto-Sign] Failed to sign: {}", out_filename.display()));
+            let _ = std::fs::remove_file(&tmp_signed);
+        }
+    }
+}
+// OHOS PATCH END
